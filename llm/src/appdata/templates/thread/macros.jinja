{% macro render_chat_history(history) %}
<conversation>
{% for message in history %}
    {% if message.type == "ai" %}
        <ai turn="{{ loop.index }}">{{ message.content }}</ai>
    {% elif message.type == "human" or message.type == "patient" %}
        <patient turn="{{ loop.index }}">{{ message.content }}</patient>
    {% elif message.type == "operator" %}
        <operator turn="{{ loop.index }}">{{ message.content }}</operator>
    {% endif %}
{% endfor %}
</conversation>
{% endmacro %}